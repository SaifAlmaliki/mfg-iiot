                  "generator": {
                    "mode": "dynamic",
                    "baseValue": 72.5,
                    "noise": {
                      "type": "gaussian",
                      "amplitude": 2
                    }
                  }
                },
                {
                  "address": 2,
                  "name": "Pressure",
                  "value": 98.3,
                  "dataType": "float32",
                  "description": "Current pressure (bar)",
                  "generator": {
                    "mode": "dynamic",
                    "baseValue": 98.3,
                    "noise": {
                      "type": "gaussian",
                      "amplitude": 1.5
                    }
                  }
                },
                {
                  "address": 4,
                  "name": "Flow_Rate",
                  "value": 485,
                  "dataType": "int16",
                  "description": "Current flow rate (L/min)",
                  "generator": {
                    "mode": "dynamic",
                    "baseValue": 485,
                    "noise": {
                      "type": "uniform",
                      "amplitude": 20
                    }
                  }
                },
                {
                  "address": 5,
                  "name": "Level",
                  "value": 75,
                  "dataType": "int16",
                  "description": "Tank level (%)"
                },
                {
                  "address": 6,
                  "name": "Motor_Speed",
                  "value": 1450,
                  "dataType": "int16",
                  "description": "Motor speed (RPM)",
                  "generator": {
                    "mode": "dynamic",
                    "baseValue": 1450,
                    "noise": {
                      "type": "gaussian",
                      "amplitude": 30
                    }
                  }
                }
              ]
            }
          },
          {
            "slaveId": 2,
            "name": "Unit 2",
            "enabled": true,
            "registers": {
              "coils": [],
              "discreteInputs": [],
              "holdingRegisters": [
                {
                  "address": 0,
                  "name": "SP2_Temp",
                  "value": 50,
                  "dataType": "int16",
                  "description": "Secondary temp setpoint"
                }
              ],
              "inputRegisters": [
                {
                  "address": 0,
                  "name": "Temp2",
                  "value": 48.2,
                  "dataType": "float32",
                  "description": "Secondary temperature",
                  "generator": {
                    "mode": "dynamic",
                    "baseValue": 48.2,
                    "noise": {
                      "type": "gaussian",
                      "amplitude": 1
                    }
                  }
                }
              ]
            }
          }
        ]
      },
      "status": "running"
    },
