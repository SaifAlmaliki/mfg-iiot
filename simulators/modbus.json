{
  "simulators": [
    {
      "id": "modbus-1",
      "name": "Modbus TCP Boiler Line 1",
      "type": "modbus",
      "enabled": true,
      "port": 5020,
      "description": "Production Line A – boiler line 1: pumps, valves, temperature and pressure control",
      "productionLine": "A",
      "config": {
        "maxConnections": 50,
        "connectionTimeout": 30000,
        "frameTimeout": 5000,
        "slaves": [
          {
            "slaveId": 1,
            "name": "Unit 1",
            "enabled": true,
            "registers": {
              "coils": [
                {
                  "address": 0,
                  "name": "Pump_Start",
                  "value": false,
                  "description": "Start pump"
                },
                {
                  "address": 1,
                  "name": "Pump_Stop",
                  "value": false,
                  "description": "Stop pump"
                },
                {
                  "address": 2,
                  "name": "Valve_Open",
                  "value": true,
                  "description": "Open valve"
                },
                {
                  "address": 3,
                  "name": "Valve_Close",
                  "value": false,
                  "description": "Close valve"
                }
              ],
              "discreteInputs": [
                {
                  "address": 0,
                  "name": "Pump_Running",
                  "value": true,
                  "description": "Pump is running"
                },
                {
                  "address": 1,
                  "name": "Valve_Open_Status",
                  "value": true,
                  "description": "Valve is open"
                },
                {
                  "address": 2,
                  "name": "High_Level_Alarm",
                  "value": false,
                  "description": "High level alarm"
                }
              ],
              "holdingRegisters": [
                {
                  "address": 0,
                  "name": "Setpoint_Temp",
                  "value": 75,
                  "dataType": "int16",
                  "description": "Temperature setpoint (°C)"
                },
                {
                  "address": 1,
                  "name": "Setpoint_Pressure",
                  "value": 100,
                  "dataType": "int16",
                  "description": "Pressure setpoint (bar)"
                },
                {
                  "address": 2,
                  "name": "Flow_Rate_SP",
                  "value": 500,
                  "dataType": "int16",
                  "description": "Flow rate setpoint (L/min)"
                },
                {
                  "address": 10,
                  "name": "Mode_Select",
                  "value": 1,
                  "dataType": "int16",
                  "description": "0=Manual, 1=Auto, 2=Service"
                },
                {
                  "address": 11,
                  "name": "Ramp_Rate",
                  "value": 5,
                  "dataType": "int16",
                  "description": "Ramp rate (°C/min)"
                }
              ],
              "inputRegisters": [
